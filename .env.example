# Public canonical URL used for SEO canonical/alternate URLs.
NUXT_PUBLIC_SITE_URL=https://gaetancanovas.dev

# Leave empty to disable analytics.
# Supported values in this scaffold: cloudflare, plausible
NUXT_PUBLIC_ANALYTICS_PROVIDER=

# Cloudflare Web Analytics token, only used when provider=cloudflare.
NUXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# Plausible domain, only used when provider=plausible.
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=gaetancanovas.dev
